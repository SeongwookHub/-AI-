# 네이버 개발자센터(https://developers.naver.com/apps/#/register)에서
# "검색" API를 사용하는 애플리케이션을 등록하면 아래 두 값을 발급받을 수 있습니다.
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# 대시보드 접속 시 요구할 비밀번호. 비워두면 인증 없이 접근 가능(로컬 개발용).
# 배포 시에는 반드시 값을 설정하세요.
APP_PASSWORD=

# 세션 쿠키 서명용 비밀키. 설정하지 않으면 자동 생성되어 output/.session_secret에 저장되지만,
# 배포 환경(컨테이너 재시작 시 파일시스템이 초기화되는 경우)에서는 값을 고정해야
# 재배포 후에도 로그인 세션이 유지된다. 예: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# 배포 환경에서 SQLite/원시 응답/파이프라인 상태 파일을 저장할 영구 디스크 경로.
# 로컬 개발에서는 비워두면 프로젝트 내 output/ 폴더를 사용한다.
DATA_DIR=
